{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/nemotron-3-ultra-free",
  "autoupdate": true,
  "mcp": {
    "obsidian": {
      "type": "local",
      "command": ["{{MCPVAULT_CMD}}", "{{VAULT_PATH}}"],
      "enabled": true
    },
    "academic-research": {
      "type": "local",
      "command": ["npx", "-y", "@thenextgennexus/academic-research-mcp-server"],
      "enabled": true
    },
    "notebooklm": {
      "type": "local",
      "command": ["npx", "-y", "@mcpware/notebooklm-api"],
      "environment": { "GEMINI_API_KEY": "{env:GEMINI_API_KEY}" },
      "enabled": false,
      "description": "Opcional: Q&A sobre documentos con Gemini. Requiere API key gratis en aistudio.google.com y variable de entorno GEMINI_API_KEY"
    }
  },
  "agent": {
    "oracle": {
      "model": "opencode/nemotron-3-ultra-free",
      "mode": "subagent",
      "description": "Analisis, debugging y arquitectura (1M contexto, gratis)."
    },
    "fixer": {
      "model": "opencode/glm-5-free",
      "mode": "subagent",
      "description": "Implementacion de codigo y documentos."
    },
    "explorer": {
      "model": "opencode/deepseek-v4-flash-free",
      "mode": "subagent",
      "description": "Busqueda de codigo y simbolos."
    },
    "librarian": {
      "model": "opencode/deepseek-v4-flash-free",
      "mode": "subagent",
      "description": "Documentacion externa e investigacion."
    }
  },
  "skills": {},
  "plugin": [
    "oh-my-opencode",
    "opencode-vibeguard",
    "opencode-websearch-cited",
    "opencode-pty",
    "opencode-supermemory",
    "opencode-snip",
    "opencode-working-memory",
    "opencode-orchestrator",
    "opencode-dux"
  ],
  "disabled_providers": ["ollama", "openrouter"],
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": { "baseURL": "http://localhost:11434/v1" },
      "models": { "llama3.2": { "name": "Llama 3.2 Local" } }
    }
  }
}