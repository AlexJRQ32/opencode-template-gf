{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/qwen3.6-plus-free",
  "autoupdate": true,
  "mcp": {
    "obsidian": {
      "type": "local",
      "command": [
        "{{MCPVAULT_CMD}}",
        "{{VAULT_PATH}}"
      ],
      "enabled": true
    }
  },
  "agent": {
    "nemotron-3-ultra": {
      "model": "opencode/nemotron-3-ultra-free",
      "mode": "subagent",
      "description": "Nemotron 3 Ultra (1M contexto). Tareas grandes."
    },
    "deepseek-v4-flash": {
      "model": "opencode/deepseek-v4-flash-free",
      "mode": "subagent",
      "description": "DeepSeek V4 Flash. Codigo, analisis, debugging."
    },
    "qwen-36-plus": {
      "model": "opencode/qwen3.6-plus-free",
      "mode": "subagent",
      "description": "Qwen3.6 Plus. Codigo, features, refactors."
    },
    "grok-code-fast-1": {
      "model": "opencode/grok-code-fast-1-free",
      "mode": "subagent",
      "description": "Grok Code Fast 1. Codigo rapido, explicaciones."
    },
    "glm-5": {
      "model": "opencode/glm-5-free",
      "mode": "subagent",
      "description": "GLM 5. Proposito general, analisis, creatividad."
    },
    "ring-26-1t": {
      "model": "opencode/ring-2.6-1t-free",
      "mode": "subagent",
      "description": "Ring 2.6 1T. Razonamiento, tareas complejas."
    },
    "gpt-5-nano": {
      "model": "opencode/gpt-5-nano",
      "mode": "subagent",
      "description": "GPT 5 Nano. Tareas rapidas y ligeras."
    },
    "minimax-m25": {
      "model": "opencode/minimax-m2.5-free",
      "mode": "subagent",
      "description": "MiniMax M2.5. Proposito general."
    },
    "orquestrador": {
      "model": "opencode-go/qwen3.7-max",
      "mode": "all",
      "description": "Orquestrador de agentes y tareas."
    },
    "hive-master": {
      "model": "opencode-go/qwen3.7-max",
      "mode": "all",
      "description": "Coordinador de enjambre."
    },
    "swarm": {
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "all",
      "description": "Swarm: Ejecucion masiva paralela."
    },
    "architect": {
      "model": "opencode-go/qwen3.7-max",
      "mode": "all",
      "description": "Diseno de arquitectura."
    },
    "scout": {
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "all",
      "description": "Exploracion rapida de codigo."
    },
    "forager": {
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "all",
      "description": "Recoleccion de informacion."
    },
    "hygienic": {
      "model": "opencode-go/deepseek-v4-pro",
      "mode": "all",
      "description": "Limpieza y refactorizacion."
    }
  },
  "skills": {},
  "plugin": [
    "oh-my-opencode",
    "opencode-vibeguard",
    "opencode-websearch-cited",
    "opencode-pty",
    "opencode-wakatime",
    "opencode-worktree",
    "opencode-background-agents",
    "opencode-supermemory",
    "opencode-goal-plugin",
    "opencode-conductor",
    "opencode-quota",
    "opencode-snip",
    "opencode-claude-memory",
    "opencode-working-memory",
    "opencode-swarm",
    "opencode-orchestrator",
    "opencode-hive",
    "opencode-lazy",
    "opencode-codeindex",
    "opencode-models-discovery",
    "opencode-copilot-plugin",
    "@openspoon/subtask2",
    "@plannotator/opencode",
    "@hueyexe/opencode-ensemble",
    "@capybearista/opencode-agents-loader",
    "opencode-dux",
    "opencode-agent-trace-plugin",
    "opencode-mem"
  ],
  "disabled_providers": ["ollama", "openrouter"],
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": { "baseURL": "http://localhost:11434/v1" },
      "models": { "llama3.2": { "name": "Llama 3.2 Local" } }
    }
  }
}
